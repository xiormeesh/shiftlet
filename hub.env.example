# Hub cluster — runs MCE/ACM, needs more RAM for the operator stack
NAME=hub
VERSION=4.21.5
# Minimum 16 GB — installer enforces this for master nodes
MEMORY_GB=25
PULL_SECRET=~/.config/openshift/pull-secret

# Network mode: NAT (default) or bridge
#
# NAT (default):
#   - Isolated network, works on WiFi
#   - Single-host only
#   - VM not reachable from LAN
#
# bridge (experimental):
#   - VM on LAN with explicit IP
#   - Requires wired ethernet and br0 bridge (see README)
#   - Enables cross-host multi-cluster
NETWORK_MODE=NAT

# Required when NETWORK_MODE=bridge: explicit LAN IP for the VM.
# Each cluster on the LAN must use a unique IP outside your DHCP pool.
# Example: hub on host A gets .80, spoke on host B gets .81
#BRIDGE_VM_IP=192.168.1.80

# Capabilities reference (all available since OCP 4.14):
#   baremetal          - Bare metal host management (Metal3/Ironic)
#   Build              - OpenShift Builds (BuildConfig, S2I)
#   CloudCredential    - Cloud provider credential management (CCO)
#   Console            - Web console UI
#   CSISnapshot        - Volume snapshot support
#   DeploymentConfig   - Legacy deployment mechanism (deprecated)
#   ImageRegistry      - Internal container image registry
#   Ingress            - Cluster ingress/router (HAProxy, *.apps routes)
#   Insights           - Red Hat Insights telemetry
#   MachineAPI         - Machine lifecycle management
#   marketplace        - OperatorHub / community operators catalog
#   NodeTuning         - Node performance tuning (TuneD)
#   openshift-samples  - Sample imagestreams and templates
#   OperatorLifecycleManager - OLM (install operators from catalogs)
#   Storage            - Storage operator (CSI drivers)
#
# Empty string = baselineCapabilitySet: None with no additions
# Unset = default set (Ingress OperatorLifecycleManager marketplace Console)
# Capabilities can be enabled post-install but not disabled
CAPABILITIES="Ingress Console OperatorLifecycleManager marketplace MachineAPI"
